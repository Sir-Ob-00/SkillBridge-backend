generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  student
  artisan
  admin
  super_admin
}

enum ApplicationStatus {
  EMAIL_VERIFICATION_PENDING
  PENDING_PROFILE
  PENDING_REVIEW
  UNDER_REVIEW
  CHANGES_REQUESTED
  ACTIVE
  REJECTED
}

enum VerificationReviewStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum BookingStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
  rejected
}

enum ReportStatus {
  open
  resolved
  escalated
}

// ─────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(student)
  phone        String?
  avatarUrl    String?
  isSuspended  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artisanProfile ArtisanProfile?
  studentProfile StudentProfile?

  refreshTokens   RefreshToken[]
  bookingsAsStudent Booking[] @relation("StudentBookings")
  reviewsWritten    Review[] @relation("StudentReviews")

  reportsFiled   Report[] @relation("ReporterReports")
  reportsAgainst Report[] @relation("TargetReports")

  messagesSent     Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// ARTISANS (normalized onboarding / verification)
// ─────────────────────────────────────────────────────────────────────────

model ArtisanProfile {
  id                String           @id @default(uuid())
  userId            String           @unique
  businessName      String?
  bio               String?
  pricingFrom       Decimal?         @db.Decimal(10, 2)
  location          String?
  yearsOfExperience Int?
  rating            Decimal          @default(0) @db.Decimal(3, 2)
  reviewCount       Int              @default(0)
  profileImageUrl   String?
  isSuspended       Boolean          @default(false)
  status            ApplicationStatus @default(PENDING_PROFILE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills        ArtisanSkill[]
  categories    ArtisanCategory[]
  services      ArtisanService[]
  portfolio     ArtisanPortfolio[]
  availability  ArtisanAvailability[]
  verification  ArtisanVerification?
  applicationHistory ApplicationStatusHistory[]

  bookings Booking[] @relation("ArtisanBookings")
  reviews  Review[]  @relation("ArtisanReviews")
  savedBy  SavedArtisan[]

  @@index([status])
  @@map("artisan_profiles")
}

model ArtisanSkill {
  id        String         @id @default(uuid())
  artisanId String
  name      String
  artisan   ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([artisanId, name])
  @@index([name])
  @@map("artisan_skills")
}

model ArtisanCategory {
  id        String         @id @default(uuid())
  artisanId String
  name      String
  artisan   ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([artisanId, name])
  @@index([name])
  @@map("artisan_categories")
}

model ArtisanService {
  id              String         @id @default(uuid())
  artisanId       String
  title           String
  description     String
  price           Decimal        @db.Decimal(10, 2)
  durationMinutes Int
  category        String
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("artisan_services")
}

model ArtisanPortfolio {
  id          String         @id @default(uuid())
  artisanId   String
  imageUrl    String
  title       String
  description String?
  createdAt   DateTime       @default(now())

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("artisan_portfolio")
}

model ArtisanAvailability {
  id        String         @id @default(uuid())
  artisanId String
  day       String
  startTime String
  endTime   String

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("artisan_availability")
}

model ArtisanVerification {
  id                  String                 @id @default(uuid())
  artisanId           String                 @unique
  institution         String
  studentIdNumber     String
  verificationImageUrl String
  reviewStatus        VerificationReviewStatus @default(PENDING)
  reviewNotes         String?
  reviewedBy          String?
  reviewedAt          DateTime?
  submittedAt         DateTime               @default(now())

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("artisan_verifications")
}

model ApplicationStatusHistory {
  id        String           @id @default(uuid())
  artisanId String
  status    ApplicationStatus
  note      String?
  changedBy String?
  createdAt DateTime         @default(now())

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("application_status_history")
}

// ─────────────────────────────────────────────────────────────────────────
// STUDENTS
// ─────────────────────────────────────────────────────────────────────────

model StudentProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  campus    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedArtisans SavedArtisan[]

  @@map("student_profiles")
}

model SavedArtisan {
  id         String   @id @default(uuid())
  studentId  String
  artisanId  String
  createdAt  DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([studentId, artisanId])
  @@index([artisanId])
  @@map("saved_artisans")
}

// ─────────────────────────────────────────────────────────────────────────
// CATALOGS
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("skills")
}

// ─────────────────────────────────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(uuid())
  studentId     String
  artisanId     String
  serviceTitle  String
  price         Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(pending)
  scheduledTime DateTime
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student User           @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  artisan ArtisanProfile @relation("ArtisanBookings", fields: [artisanId], references: [id], onDelete: Cascade)
  review  Review?

  @@index([studentId])
  @@index([artisanId])
  @@index([status])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  studentId String
  artisanId String
  rating    Int
  comment   String
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())

  booking Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  student User           @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  artisan ArtisanProfile @relation("ArtisanReviews", fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@index([studentId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────
// CATEGORIES / REPORTS
// ─────────────────────────────────────────────────────────────────────────

model Report {
  id           String       @id @default(uuid())
  reporterId   String
  targetUserId String
  reason       String
  details      String?
  status       ReportStatus @default(open)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reporter User @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User @relation("TargetReports", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetUserId])
  @@map("reports")
}

// ─────────────────────────────────────────────────────────────────────────
// MESSAGES (CHAT)
// ─────────────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  chatId     String
  message    String
  readAt     DateTime?
  timestamp  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}
