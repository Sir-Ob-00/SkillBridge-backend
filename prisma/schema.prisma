generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  student
  artisan
  admin
  super_admin
}

enum BookingStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
  rejected
}

enum ReportStatus {
  open
  resolved
  escalated
}

enum ApplicationStatus {
  EMAIL_VERIFICATION_PENDING
  PENDING_PROFILE
  PENDING_REVIEW
  UNDER_REVIEW
  CHANGES_REQUESTED
  ACTIVE
  REJECTED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum VerificationReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

// ─────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(student)
  phone        String?
  profileImageUrl    String?
  emailVerified Boolean @default(false)
  isSuspended  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artisanProfile    ArtisanProfile?    @relation("ArtisanOwner")
  reviewedProfiles  ArtisanProfile[]   @relation("ArtisanReviewer")
  studentProfile    StudentProfile?
  verification      ArtisanVerification?
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailOtp          EmailVerificationOTP?
  bookingsAsStudent Booking[]          @relation("StudentBookings")
  reviewsWritten    Review[]           @relation("StudentReviews")
  reportsFiled      Report[]           @relation("ReporterReports")
  reportsAgainst    Report[]           @relation("TargetReports")
  messagesSent      Message[]          @relation("SentMessages")
  messagesReceived  Message[]          @relation("ReceivedMessages")
  statusChanges     ArtisanStatusChange[]

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationOTP {
  id        String   @id @default(uuid())
  userId    String   @unique
  otp       String
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_otps")
}

// ─────────────────────────────────────────────────────────────────────────
// ARTISANS
// ─────────────────────────────────────────────────────────────────────────

model ArtisanProfile {
  id                String            @id @default(uuid())
  userId            String            @unique
  businessName      String?
  bio               String?
  pricingFrom       Decimal?          @db.Decimal(10, 2)
  location          String?
  rating            Decimal           @default(0) @db.Decimal(3, 2)
  reviewCount       Int               @default(0)
  applicationStatus ApplicationStatus @default(PENDING_PROFILE)
  isSuspended       Boolean           @default(false)

  rejectionReason   String?
  reviewNotes       String?
  reviewedByAdminId String?
  reviewedAt        DateTime?
  submittedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verification String? @default("unverified")

  user            User                @relation("ArtisanOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewedByAdmin  User?               @relation("ArtisanReviewer", fields: [reviewedByAdminId], references: [id])
  portfolio        ArtisanPortfolio[]
  services         ArtisanService[]
  availability     ArtisanAvailability[]
  skills           ArtisanSkill[]
  categories       ArtisanCategory[]
  verificationDoc  ArtisanVerification?
  bookings         Booking[]           @relation("ArtisanBookings")
  reviews          Review[]            @relation("ArtisanReviews")
  savedBy         SavedArtisan[]
  statusHistory    ArtisanStatusChange[]

  @@index([applicationStatus])
  @@index([verification])
  @@index([userId])
  @@map("artisan_profiles")
}

model ArtisanVerification {
  id                    String                  @id @default(uuid())
  artisanProfileId      String                  @unique
  institution           String
  studentId             String
  verificationImageUrl  String
  status                VerificationReviewStatus @default(PENDING)
  reviewNotes           String?
  reviewedByUserId      String?   @unique
  reviewedAt            DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)
  reviewedBy     User?           @relation(fields: [reviewedByUserId], references: [id])

  @@index([artisanProfileId])
  @@map("artisan_verifications")
}

model ArtisanPortfolio {
  id              String   @id @default(uuid())
  artisanProfileId String
  imageUrl       String
  caption        String?
  createdAt      DateTime @default(now())

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)

  @@index([artisanProfileId])
  @@map("artisan_portfolio")
}

model ArtisanAvailability {
  id              String       @id @default(uuid())
  artisanProfileId String
  day             DayOfWeek
  startTime       String
  endTime         String
  createdAt       DateTime     @default(now())

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)

  @@unique([artisanProfileId, day])
  @@index([artisanProfileId])
  @@map("artisan_availability")
}

model ArtisanSkill {
  id              String   @id @default(uuid())
  artisanProfileId String
  skillId         String
  createdAt       DateTime @default(now())

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)
  skill          Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([artisanProfileId, skillId])
  @@index([artisanProfileId])
  @@map("artisan_skills")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  artisans ArtisanSkill[]

  @@map("skills")
}

model ArtisanCategory {
  id              String   @id @default(uuid())
  artisanProfileId String
  categoryId      String
  createdAt       DateTime @default(now())

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([artisanProfileId, categoryId])
  @@index([artisanProfileId])
  @@map("artisan_categories")
}

model ArtisanService {
  id              String   @id @default(uuid())
  artisanProfileId String
  title           String
  description     String
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int
  categoryId      String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([artisanProfileId])
  @@index([categoryId])
  @@map("artisan_services")
}

model ArtisanStatusChange {
  id                String          @id @default(uuid())
  artisanProfileId  String
  fromStatus        ApplicationStatus?
  toStatus          ApplicationStatus
  changedByUserId   String?
  notes             String?
  createdAt         DateTime        @default(now())

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)
  changedBy      User?           @relation(fields: [changedByUserId], references: [id])

  @@index([artisanProfileId])
  @@index([createdAt])
  @@index([toStatus])
  @@map("application_status_history")
}

// ─────────────────────────────────────────────────────────────────────────
// STUDENTS
// ─────────────────────────────────────────────────────────────────────────

model StudentProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  campus    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedArtisans SavedArtisan[]

  @@map("student_profiles")
}

model SavedArtisan {
  id         String   @id @default(uuid())
  studentId  String
  artisanId  String
  createdAt  DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([studentId, artisanId])
  @@index([artisanId])
  @@map("saved_artisans")
}

// ─────────────────────────────────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────────────────────────────────

model Booking {
  id            String         @id @default(uuid())
  studentId     String
  artisanId     String
  serviceTitle  String
  price         Decimal        @db.Decimal(10, 2)
  status        BookingStatus  @default(pending)
  scheduledTime DateTime
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  student User           @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  artisan ArtisanProfile @relation("ArtisanBookings", fields: [artisanId], references: [id], onDelete: Cascade)
  review  Review?

  @@index([studentId])
  @@index([artisanId])
  @@index([status])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  studentId String
  artisanId String
  rating    Int
  comment   String
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())

  booking Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  student User           @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  artisan ArtisanProfile @relation("ArtisanReviews", fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@index([studentId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artisans     ArtisanCategory[]
  services     ArtisanService[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────────────
// REPORTS
// ─────────────────────────────────────────────────────────────────────────

model Report {
  id           String       @id @default(uuid())
  reporterId   String
  targetUserId String
  reason       String
  details      String?
  status       ReportStatus @default(open)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reporter User @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User @relation("TargetReports", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetUserId])
  @@map("reports")
}

// ─────────────────────────────────────────────────────────────────────────
// MESSAGES (CHAT)
// ─────────────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  chatId     String
  message    String
  readAt     DateTime?
  timestamp  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}
