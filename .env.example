# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:Owusu.Boateng89@localhost:5432/skillbridge?schema=public

# JWT
JWT_ACCESS_SECRET=skillbridge_access_secret_2026_super_secure
JWT_REFRESH_SECRET=skillbridge_refresh_secret_2026_super_secure
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
CORS_ORIGIN="*"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Brevo SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_brevo_login_email
EMAIL_PASS=your_brevo_smtp_key
EMAIL_FROM="SkillBridge <no-reply@skillbridge.dev>"
EMAIL_OTP_TTL_MINUTES=10
FRONTEND_URL=https://your-frontend-url.com
